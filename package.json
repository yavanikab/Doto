{
  "name": "doto",
  "version": "1.0.0",
  "description": "Minimalist Windows desktop checklist app",
  "author": "Doto",
  "main": "electron/main.js",
  "build": {
    "appId": "com.doto.app",
    "productName": "Doto",
    "directories": {
      "output": "dist"
    },
    "compression": "maximum",
    "removePackageScripts": true,
    "removePackageKeywords": true,
    "asarUnpack": [
      "dist-vite/icon.ico",
      "dist-vite/icon.png"
    ],
    "win": {
      "icon": "src/assets/icon.ico",
      "certificateFile": null,
      "signAndEditExecutable": false,
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "files": [
      "dist-vite/**/*",
      "electron/**/*",
      "package.json",
      "!AGENTS.md",
      "!**/node_modules/.cache",
      "!**/*.map",
      "!**/*.d.ts",
      "!**/*.d.ts.map"
    ]
  },
  "scripts": {
    "dev": "vite",
    "dev:electron": "vite build && electron .",
    "build": "vite build && node -e \"require('fs').copyFileSync('src/assets/icon.ico','dist-vite/icon.ico')\" && electron-builder --win --dir && node -e \"require('child_process').execFileSync('scripts/rcedit-x64.exe',['dist/win-unpacked/Doto.exe','--set-icon','src/assets/icon.ico'])\" && node -e \"require('fs').readdirSync('dist/win-unpacked').filter(f=>['d3dcompiler_47.dll','LICENSES.chromium.html','vk_swiftshader.dll'].includes(f)).forEach(f=>require('fs').unlinkSync('dist/win-unpacked/'+f))\" && electron-builder --win --prepackaged dist/win-unpacked",
    "preview": "vite preview",
    "lint": "eslint . --ext .js,.vue --fix && prettier --write .",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "archiver": "^7.0.1",
    "archiver-utils": "^5.0.2",
    "marked": "^18.0.3",
    "turndown": "^7.2.4",
    "vue": "^3.5.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.2.0",
    "electron": "^33.0.0",
    "electron-builder": "^25.1.0",
    "eslint": "^8.0.0",
    "eslint-plugin-vue": "^9.32.0",
    "prettier": "^3.4.0",
    "vite": "^6.0.0",
    "vitest": "^3.0.0"
  }
}
